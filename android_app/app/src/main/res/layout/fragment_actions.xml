<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textSize="20sp"
            android:textColor="@color/accent"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Custom Actions"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareAll"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📤"
            android:textSize="18sp"
            android:textAllCaps="false"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Override default gesture actions with your own.\nExample: C → Call Mom (01012345678)"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="12dp"/>

    <!-- Quick Presets -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quick Presets"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/presetKakao"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="💬 카카오톡"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                app:strokeColor="#FEE500"
                app:cornerRadius="20dp"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/presetYoutube"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="▶ 유튜브"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                app:strokeColor="#FF0000"
                app:cornerRadius="20dp"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/presetNaver"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🟢 네이버"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                app:strokeColor="#03C75A"
                app:cornerRadius="20dp"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/presetChrome"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🌐 크롬"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                app:strokeColor="#4285F4"
                app:cornerRadius="20dp"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/presetMaps"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="📍 지도"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                app:strokeColor="#34A853"
                app:cornerRadius="20dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Add Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="14dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Add New Mapping" android:textColor="@color/text_primary"
                android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Gesture letter (A-Z)" app:boxBackgroundColor="@color/bg_surface"
                app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="@color/text_muted" android:layout_marginBottom="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputGesture" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="@color/text_primary"
                    android:inputType="textCapCharacters" android:maxLength="1"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Action type"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="@color/text_muted" android:layout_marginBottom="8dp">
                <AutoCompleteTextView
                    android:id="@+id/inputActionType" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="@color/text_primary"
                    android:inputType="none"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Value (phone number, URL, etc.)" app:boxBackgroundColor="@color/bg_surface"
                app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp"
                app:hintTextColor="@color/text_muted" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputActionValue" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="@color/text_primary"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddMapping" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="Add" android:textAllCaps="false"
                android:textColor="#FFFFFF" app:backgroundTint="@color/accent" app:cornerRadius="10dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Saved Mappings"
            android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearAll"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="전체 삭제" android:textSize="12sp"
            android:textColor="@color/status_disconnected" android:textAllCaps="false"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:id="@+id/mappingListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

</LinearLayout>
