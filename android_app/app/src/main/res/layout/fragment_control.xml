<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <!-- ═══ Header ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textSize="20sp"
            android:textColor="@color/accent"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AirWriting Control"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ═══ Status ═══ -->
    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="14dp"
        android:background="@drawable/status_bg_disconnected"
        android:layout_marginBottom="12dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/status_disconnected"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Not Connected"
            android:textColor="@color/status_disconnected"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDisconnect"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Disconnect"
            android:textSize="11sp"
            android:textColor="@color/status_disconnected"
            android:textAllCaps="false"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- ═══ Real-time Recognition Card ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/recognitionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/recognition_card_bg"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recognized"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.15"/>

            <TextView
                android:id="@+id/txtRecognizedLetter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/recognition_letter"
                android:textSize="72sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/txtRecognitionDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting for gesture..."
                android:textColor="@color/recognition_confidence"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══ Quick Stats Row ═══ -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="14dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="2dp"
            android:layout_marginEnd="6dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center">
                <TextView
                    android:id="@+id/statActionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/accent"
                    android:textSize="28sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Actions"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="14dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="2dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center">
                <TextView
                    android:id="@+id/statUptime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/accent"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uptime"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="14dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="2dp"
            android:layout_marginStart="6dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center">
                <TextView
                    android:id="@+id/statLastAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/accent"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ═══ QR Scan Button ═══ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScanQr"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📷  Scan QR to Connect"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        app:backgroundTint="@color/accent"
        app:cornerRadius="14dp"
        android:layout_marginBottom="10dp"/>

    <!-- ═══ Manual IP (collapsed) ═══ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggleManual"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="직접 IP 입력 ▼"
        android:textSize="13sp"
        android:textColor="@color/text_muted"
        android:textAllCaps="false"/>

    <LinearLayout
        android:id="@+id/manualInputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="8dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Server IP"
            app:boxBackgroundColor="@color/bg_card"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:hintTextColor="@color/text_muted"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ipInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textUri"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Connect"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:backgroundTint="@color/accent"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <!-- ═══ Log Card ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="16dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        app:cardElevation="2dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Activity Log"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearLog"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Clear"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:textAllCaps="false"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleLog"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="▲"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted"
                    android:textAllCaps="false"/>
            </LinearLayout>

            <ScrollView
                android:id="@+id/logScroll"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="@color/log_bg"
                android:padding="10dp">
                <TextView
                    android:id="@+id/logText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"/>
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══ Supported Gestures ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="16dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supported Gestures"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="C · Call    M · Message    P · Camera\nS · Search    W · Weather    N · Notes\nT · Timer    A · Alarm    B · Bixby\nG · Gemini    H · Home    V · Gallery"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="5dp"
                android:fontFamily="monospace"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
</ScrollView>
