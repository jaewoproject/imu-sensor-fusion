<?xml version="1.0" encoding="utf-8"?>
<!-- Qorvo UWB Explorer-inspired layout for AirWriting Control -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- ═══ BLACK HEADER (Qorvo Style) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/qorvo_header_bg"
        android:gravity="center"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AirWriting"
            android:textSize="28sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v2.0"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- ═══ MAIN CONTENT (White Section) ═══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Selected Device Section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selected device"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"/>

                <TextView
                    android:id="@+id/txtDeviceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No selected device"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOT CONNECTED"
                    android:textSize="13sp"
                    android:textColor="@color/status_disconnected"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- ── 3-Column Metric Cards (distance / azimuth / elevation style) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/bg_card"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp"
                android:gravity="center">

                <!-- Metric 1: Actions (like distance) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↗"
                        android:textSize="24sp"
                        android:textColor="@color/accent"/>

                    <TextView
                        android:id="@+id/statActionCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="actions"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Metric 2: Uptime (like azimuth) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱"
                        android:textSize="24sp"
                        android:textColor="@color/accent"/>

                    <TextView
                        android:id="@+id/statUptime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="uptime"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Metric 3: Last Action (like elevation) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✎"
                        android:textSize="24sp"
                        android:textColor="@color/accent"/>

                    <TextView
                        android:id="@+id/statLastAction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="last"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Recognition Card (visible when connected) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/recognitionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/border_active"
                app:strokeWidth="1dp"
                app:cardElevation="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/recognition_card_bg"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECOGNIZED"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"/>

                    <TextView
                        android:id="@+id/txtRecognizedLetter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/recognition_letter"
                        android:textSize="72sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/txtRecognitionDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting for gesture..."
                        android:textColor="@color/recognition_confidence"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ AVAILABLE DEVICES SECTION (Light Gray, Qorvo-style) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/qorvo_devices_bg"
                android:layout_marginTop="8dp">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Available devices"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>

                    <!-- Cyan Refresh Button (Qorvo Style) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScanQr"
                        style="@style/Widget.MaterialComponents.Button.Icon"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:icon="@android:drawable/ic_popup_sync"
                        app:iconGravity="textStart"
                        app:iconSize="20dp"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="22dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"/>
                </LinearLayout>

                <!-- QR Scan / Connect Area -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleManual"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="📷  Scan QR to Connect"
                        android:textSize="14sp"
                        android:textColor="@color/accent"
                        android:textAllCaps="false"
                        app:strokeColor="@color/accent"
                        app:cornerRadius="12dp"/>
                </LinearLayout>

                <!-- Manual IP Input -->
                <LinearLayout
                    android:id="@+id/manualInputContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Server IP"
                        app:boxBackgroundColor="@color/bg_card"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:hintTextColor="@color/text_muted"
                        android:layout_marginBottom="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/ipInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:inputType="textUri"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConnect"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Connect"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="12dp"/>
                </LinearLayout>

                <!-- Device Discovery Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp">

                    <TextView
                        android:id="@+id/txtNoDevices"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No devices discovered"
                        android:textSize="14sp"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>

                <!-- Disconnect Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDisconnect"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:text="Disconnect"
                    android:textSize="12sp"
                    android:textColor="@color/status_disconnected"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <!-- ═══ Activity Log (collapsible) ═══ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Activity Log"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnClearLog"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:text="Clear"
                                android:textSize="11sp"
                                android:textColor="@color/text_muted"
                                android:textAllCaps="false"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnToggleLog"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:text="▲"
                                android:textSize="14sp"
                                android:textColor="@color/text_muted"
                                android:textAllCaps="false"/>
                        </LinearLayout>

                        <ScrollView
                            android:id="@+id/logScroll"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:background="@color/log_bg"
                            android:padding="10dp">
                            <TextView
                                android:id="@+id/logText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:fontFamily="monospace"
                                android:lineSpacingExtra="3dp"/>
                        </ScrollView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══ Supported Gestures ═══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/bg_card"
                    android:padding="16dp"
                    android:layout_marginTop="1dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Supported Gestures"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="C · Call    M · Message    P · Camera\nS · Search    W · Weather    N · Notes\nT · Timer    A · Alarm    B · Bixby\nG · Gemini    H · Home    V · Gallery"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="5dp"
                        android:fontFamily="monospace"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
